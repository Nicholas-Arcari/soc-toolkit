# sec-toolkit - shared environment configuration
# Copy this file to .env and fill in your API keys.
# Both soc-toolkit and osint-toolkit read from this same .env,
# so API keys only need to be set once.

# VirusTotal - https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AbuseIPDB - https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Shodan - https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# URLScan.io - https://urlscan.io/user/profile/
URLSCAN_API_KEY=your_urlscan_api_key_here

# AlienVault OTX - https://otx.alienvault.com/api
OTX_API_KEY=your_otx_api_key_here

# MalwareBazaar - https://bazaar.abuse.ch/api/
# Note: MalwareBazaar does not require an API key for basic queries

# --- IOC pivoting / OSINT enrichment ---

# crt.sh (Certificate Transparency) - https://crt.sh/
# Note: crt.sh is free and public, no API key required

# SecurityTrails (passive DNS, WHOIS history) - https://securitytrails.com/
# Free tier is ~50 req/month; degraded mode if omitted
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here

# Censys (service discovery) - https://search.censys.io/account/api
# Requires both API ID and secret; free tier is region-restricted
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here

# Have I Been Pwned (breach lookup) - https://haveibeenpwned.com/API/Key
# Paid account ($3.50/month) required for account- and domain-search
# endpoints. Omitting the key returns a degraded "unavailable" response
# instead of an error, so the UI still works.
HIBP_API_KEY=your_hibp_api_key_here

# --- Application Settings (shared) ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_SECRET_KEY=change-this-to-a-random-secret-key
RATE_LIMIT_PER_MINUTE=30

# Structured-log output. Defaults to JSON (one event per line,
# aggregator-ready). Set to "console" for human-readable local dev.
LOG_FORMAT=json
LOG_LEVEL=INFO

# Optional shared secret - when set, every /api/* request must carry
# `X-API-Key: <this value>`. Leave blank for an unauthenticated local
# install; always set for anything exposed beyond loopback.
API_KEY=

# --- Per-user authentication (JWT) ---
# When AUTH_SECRET is empty, auth is disabled (local-dev default). To
# enable: generate 32+ bytes of entropy (`openssl rand -hex 32`) and set
# it here. First visit to the UI will prompt admin signup; thereafter
# signup is disabled and only login works. Tokens live for 60 minutes
# by default - tune with AUTH_TOKEN_TTL_MINUTES.
AUTH_SECRET=
AUTH_TOKEN_TTL_MINUTES=60
# SQLite-backed; a legacy data/users.json is imported once on first start.
AUTH_USERS_FILE=data/users.db
# AUTH_MODE controls registration. "single-tenant" (default): only the
# first signup is allowed (it becomes admin); later signups are rejected
# - the right posture for a self-hosted clone. "saas": self-registration
# stays open and each new account gets a TRIAL_DAYS free trial. Only set
# this to "saas" on the hosted instance you operate.
AUTH_MODE=single-tenant
TRIAL_DAYS=7
# Separate license-server for SaaS paid plans (doppio binario). Leave empty
# for self-host / single-tenant. On the hosted SaaS, point LICENSE_SERVER_URL
# at your license-server and set LICENSE_SERVER_API_KEY to its
# LICENSE_CLIENT_API_KEY.
LICENSE_SERVER_URL=
LICENSE_SERVER_API_KEY=
# Email delivery for verification + password reset. Leave SMTP_HOST empty for
# dev mode (links are logged, not sent). APP_BASE_URL is the public frontend
# URL used to build the links.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@soc-toolkit.local
SMTP_STARTTLS=true
APP_BASE_URL=http://localhost:5173

# --- soc-toolkit ---
# Disposable cache for IOC enrichment responses - safe to delete.
DATABASE_URL=sqlite:///./soc_toolkit.db
APP_PORT=8000
VITE_API_URL=http://localhost:8000/api

# --- osint-toolkit ---
# Persistent state (targets, scans, findings). Namespaced so the
# two toolkits can share this .env without colliding on DB URLs.
OSINT_DATABASE_URL=sqlite+aiosqlite:///./osint_toolkit.db

# Active scanning (Amass/Subfinder subprocess) is opt-in. Leave
# false unless you have written authorization for every target.
OSINT_ENABLE_ACTIVE_SCANNING=false

# Optional outbound webhook - when set, a JSON payload is POSTed for
# every new high/critical finding. Compatible with Slack/Discord/Teams
# "incoming webhook" URLs and generic JSON receivers alike. Leave blank
# to keep the toolkit silent.
OSINT_WEBHOOK_URL=
